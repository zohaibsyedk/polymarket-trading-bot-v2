# Risk
PMB2_MAX_POSITION_USD=100
PMB2_MAX_TOTAL_OPEN_USD=300
PMB2_MIN_BUY_TRIGGER_PRICE=0.74
PMB2_MIN_BUY_FILL_PRICE=0.74
PMB2_PAUSE_ON_BUY_FILL_BELOW_MIN=1
