# PolyMarket Trading Bot V2
PMB2_STARTING_CASH=1000
PMB2_POLL_SECONDS=2
PMB2_FINAL_ENTRY_WINDOW_SECONDS=70
PMB2_ENTRY_POLL_START_SECONDS=80

# Mode
PMB2_TRADING_MODE=paper
PMB2_LIVE_BRIDGE_CMD="python3 ./scripts/polymarket_clob_bridge.py"
